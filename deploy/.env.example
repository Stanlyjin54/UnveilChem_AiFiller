# UnveilChem_AiFiller 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# ==================== 应用配置 ====================
# 应用名称和版本
APP_NAME=UnveilChem_AiFiller
APP_VERSION=1.0.0

# 调试模式 (生产环境设置为false)
DEBUG=true

# 密钥配置 (生产环境必须修改)
SECRET_KEY=your-secret-key-change-in-production

# ==================== 数据库配置 ====================
# SQLite开发环境配置
DATABASE_URL=sqlite:///./database.db

# PostgreSQL生产环境配置 (取消注释使用)
# DATABASE_URL=postgresql://username:password@host:5432/database

# ==================== JWT配置 ====================
# JWT密钥 (必须与SECRET_KEY一致)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== 文件上传配置 ====================
# 最大文件大小 (单位: 字节)
MAX_FILE_SIZE=104857600  # 100MB

# 允许的文件类型
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.txt,.png,.jpg,.jpeg

# 上传文件存储路径
UPLOAD_DIR=./uploads

# ==================== OCR配置 ====================
# Tesseract OCR路径 (本地OCR)
TESSERACT_CMD=/usr/bin/tesseract

# 阿里云OCR配置 (生产环境使用)
ALIYUN_OCR_ACCESS_KEY=your-aliyun-ocr-access-key
ALIYUN_OCR_SECRET_KEY=your-aliyun-ocr-secret-key
ALIYUN_OCR_REGION=cn-hangzhou

# ==================== 化学解析配置 ====================
# ChemDataExtractor启用状态
CHEMDATAEXTRACTOR_ENABLED=true

# ==================== 阿里云OSS配置 ====================
# 对象存储配置 (生产环境使用)
OSS_ACCESS_KEY=your-oss-access-key
OSS_SECRET_KEY=your-oss-secret-key
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=unveilchem

# ==================== 服务器配置 ====================
# 服务器监听地址和端口
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ==================== CORS配置 ====================
# 跨域请求允许的源
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== 日志配置 ====================
# 日志级别
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=./logs/app.log

# ==================== EdgeOne部署配置 ====================
# EdgeOne Pages项目名称
EDGEONE_PROJECT=unveilchem

# EdgeOne访问令牌
EDGEONE_TOKEN=your-edgeone-token

# 自定义域名 (可选)
CUSTOM_DOMAIN=www.unveilchem.com

# API基础URL (前端使用)
VITE_API_BASE_URL=https://api.unveilchem.com

# ==================== 监控配置 ====================
# 健康检查端点
HEALTH_CHECK_ENABLED=true

# 性能监控
METRICS_ENABLED=true